# ──────────────────────────────────────────────────────────────
# AMDOX ERP Platform — Environment Configuration
# Copy this file to .env and fill in the values
# ──────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=AMDOX ERP Platform
APP_VERSION=1.0.0
API_PREFIX=api
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────
DATABASE_URL=postgresql://amdox_admin:amdox_secret_2024@localhost:5432/amdox?schema=public
POSTGRES_DB=amdox
POSTGRES_USER=amdox_admin
POSTGRES_PASSWORD=amdox_secret_2024
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=amdox_redis_2024
REDIS_DB=0
REDIS_KEY_PREFIX=amdox:

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=amdox
KEYCLOAK_CLIENT_ID=amdox-api
KEYCLOAK_CLIENT_SECRET=amdox-api-secret-change-in-production
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret_2024

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_TOKEN_EXPIRATION=3600
JWT_REFRESH_TOKEN_EXPIRATION=604800
JWT_ISSUER=http://localhost:8080/realms/amdox
JWT_AUDIENCE=amdox-api
JWKS_URI=http://localhost:8080/realms/amdox/protocol/openid-connect/certs

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=amdox-api
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

# ── SMTP (for Keycloak emails) ───────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@amdox.com
