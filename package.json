{
    "name": "amdox-api",
    "version": "1.0.0",
    "description": "AMDOX ERP Platform — Multi-tenant Enterprise Resource Planning API",
    "author": "AMDOX Team",
    "private": true,
    "license": "UNLICENSED",
    "scripts": {
        "build": "nest build",
        "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
        "start": "nest start",
        "start:dev": "nest start --watch",
        "start:debug": "nest start --debug --watch",
        "start:prod": "node dist/main",
        "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
        "test": "jest",
        "test:watch": "jest --watch",
        "test:cov": "jest --coverage",
        "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
        "test:e2e": "jest --config ./test/jest-e2e.json",
        "db:generate": "prisma generate",
        "db:migrate": "prisma migrate dev",
        "db:migrate:prod": "prisma migrate deploy",
        "db:seed": "prisma db seed",
        "db:studio": "prisma studio",
        "db:reset": "prisma migrate reset",
        "docker:up": "docker compose up -d",
        "docker:down": "docker compose down",
        "format:check": "prettier --check \"src/**/*.ts\" \"apps/**/*.ts\"",
        "typecheck": "tsc --noEmit"
    },
    "prisma": {
        "seed": "ts-node prisma/seed.ts"
    },
    "dependencies": {
        "@nestjs/common": "^11.0.1",
        "@nestjs/config": "^4.0.4",
        "@nestjs/core": "^11.0.1",
        "@nestjs/jwt": "^11.0.2",
        "@nestjs/mapped-types": "^2.1.1",
        "@nestjs/passport": "^11.0.5",
        "@nestjs/platform-express": "^11.0.1",
        "@nestjs/swagger": "^11.3.1",
        "@nestjs/terminus": "^11.1.1",
        "@nestjs/throttler": "^6.5.0",
        "@prisma/client": "^7.7.0",
        "class-transformer": "^0.5.1",
        "class-validator": "^0.15.1",
        "compression": "^1.8.1",
        "cookie-parser": "^1.4.7",
        "helmet": "^8.1.0",
        "ioredis": "^5.10.1",
        "joi": "^18.1.2",
        "jwks-rsa": "^4.0.1",
        "passport": "^0.7.0",
        "passport-jwt": "^4.0.1",
        "reflect-metadata": "^0.2.2",
        "rxjs": "^7.8.1",
        "uuid": "^14.0.0"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3.2.0",
        "@eslint/js": "^9.18.0",
        "@nestjs/cli": "^11.0.0",
        "@nestjs/schematics": "^11.0.0",
        "@nestjs/testing": "^11.0.1",
        "@types/compression": "^1.8.1",
        "@types/cookie-parser": "^1.4.10",
        "@types/express": "^5.0.0",
        "@types/jest": "^30.0.0",
        "@types/node": "^24.0.0",
        "@types/passport-jwt": "^4.0.1",
        "@types/supertest": "^7.0.0",
        "@types/uuid": "^10.0.0",
        "eslint": "^9.18.0",
        "eslint-config-prettier": "^10.0.1",
        "eslint-plugin-prettier": "^5.2.2",
        "globals": "^17.0.0",
        "jest": "^30.0.0",
        "prettier": "^3.4.2",
        "prisma": "^7.7.0",
        "source-map-support": "^0.5.21",
        "supertest": "^7.0.0",
        "ts-jest": "^29.2.5",
        "ts-loader": "^9.5.2",
        "ts-node": "^10.9.2",
        "tsconfig-paths": "^4.2.0",
        "typescript": "^5.7.3",
        "typescript-eslint": "^8.20.0"
    },
    "jest": {
        "moduleFileExtensions": [
            "js",
            "json",
            "ts"
        ],
        "rootDir": "src",
        "testRegex": ".*\\.spec\\.ts$",
        "transform": {
            "^.+\\.(t|j)s$": "ts-jest"
        },
        "collectCoverageFrom": [
            "**/*.(t|j)s"
        ],
        "coverageDirectory": "../coverage",
        "testEnvironment": "node",
        "name": "amdox",
        "version": "0.1.0",
        "private": true,
        "packageManager": "pnpm@9.15.4",
        "engines": {
            "node": ">=20.0.0",
            "pnpm": ">=9.0.0"
        },
        "scripts": {
            "build": "turbo run build",
            "dev": "turbo run dev",
            "dev:web": "turbo run dev --filter=@amdox/web",
            "dev:api": "turbo run dev --filter=@amdox/api",
            "dev:ml": "cd apps/ml-service && uvicorn app.main:app --reload --port 8000",
            "lint": "turbo run lint",
            "lint:fix": "turbo run lint -- --fix",
            "test": "turbo run test",
            "test:integration": "turbo run test:integration",
            "typecheck": "turbo run typecheck",
            "clean": "turbo run clean && rm -rf node_modules .turbo",
            "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css,yaml,yml}\"",
            "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css,yaml,yml}\"",
            "db:generate": "turbo run db:generate --filter=@amdox/db",
            "db:push": "turbo run db:push --filter=@amdox/db",
            "prepare": "husky"
        },
        "devDependencies": {
            "@commitlint/cli": "^19.6.1",
            "@commitlint/config-conventional": "^19.6.0",
            "eslint": "^9.17.0",
            "husky": "^9.1.7",
            "lint-staged": "^15.4.3",
            "prettier": "^3.4.2",
            "turbo": "^2.3.3",
            "typescript": "^5.7.3"
        }
    }
}