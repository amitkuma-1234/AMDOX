KEYCLOAK_REALM=amdox
KEYCLOAK_CLIENT_ID=amdox-api
KEYCLOAK_CLIENT_SECRET=amdox-api-secret-change-in-production
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret_2024

# ── JWT ──────────────────────────────────────────────────────
