POSTGRES_DB=amdox
POSTGRES_USER=amdox_admin
POSTGRES_PASSWORD=amdox_secret_2024
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=amdox_redis_2024
REDIS_DB=0
REDIS_KEY_PREFIX=amdox:

# ── Keycloak ─────────────────────────────────────────────────
