# ─────────────────────────────────────────────────────────────
# AMDOX ERP Platform — Environment Variables
# Copy to .env and fill in actual values
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
API_PREFIX=api
APP_NAME=AMDOX
APP_VERSION=1.0.0
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Database (PostgreSQL) ───────────────────────────────────
DATABASE_URL=postgresql://amdox:amdox_secret_dev@localhost:5432/amdox_db?schema=public

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_secret_dev
REDIS_DB=0

# ── Keycloak ─────────────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=amdox
KEYCLOAK_CLIENT_ID=amdox-api
KEYCLOAK_CLIENT_SECRET=CHANGE_ME_IN_PRODUCTION
KEYCLOAK_JWKS_URI=http://localhost:8080/realms/amdox/protocol/openid-connect/certs
KEYCLOAK_TOKEN_URL=http://localhost:8080/realms/amdox/protocol/openid-connect/token
KEYCLOAK_USERINFO_URL=http://localhost:8080/realms/amdox/protocol/openid-connect/userinfo

# ── JWT ──────────────────────────────────────────────────────
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
JWT_ISSUER=amdox-api

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=60

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=amdox-api

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
