# ╔══════════════════════════════════════════════════════════════╗
# ║       AMDOX ERP Platform — Environment Variables            ║
# ║       Copy to .env and fill in your values                  ║
# ╚══════════════════════════════════════════════════════════════╝

# ─────────────────────────────────────────────────────────────
# App
# ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
APP_VERSION=1.2.0
API_PREFIX=api
LOG_LEVEL=debug

# ─────────────────────────────────────────────────────────────
# Database (PostgreSQL)
# ─────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://amdox:amdox_secret@localhost:5432/amdox?schema=public"
DB_USER=amdox
DB_PASSWORD=amdox_secret
DB_NAME=amdox

# ─────────────────────────────────────────────────────────────
# Redis
# ─────────────────────────────────────────────────────────────
REDIS_URL=redis://:amdox_redis_secret@localhost:6379
REDIS_PASSWORD=amdox_redis_secret
REDIS_TTL=300

# ─────────────────────────────────────────────────────────────
# Keycloak (Auth / OIDC)
# ─────────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=amdox
KEYCLOAK_CLIENT_ID=amdox-api
KEYCLOAK_CLIENT_SECRET=your-keycloak-client-secret

# ─────────────────────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600

# ─────────────────────────────────────────────────────────────
# CORS
# ─────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:4200

# ─────────────────────────────────────────────────────────────
# Elasticsearch (Optional — for audit log search)
# ─────────────────────────────────────────────────────────────
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=amdox-logs

# ─────────────────────────────────────────────────────────────
# OpenTelemetry (Observability)
# ─────────────────────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=amdox-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ─────────────────────────────────────────────────────────────
# Phase 3: ML Service
# ─────────────────────────────────────────────────────────────
ML_SERVICE_URL=http://localhost:8000
MLFLOW_TRACKING_URI=http://localhost:5000
ML_PORT=8000
MLFLOW_PORT=5000

# ML Service (Python) — used inside apps/ml-service
ML_DATABASE_URL="postgresql://amdox:amdox_secret@localhost:5432/amdox"
ML_REDIS_URL=redis://:amdox_redis_secret@localhost:6379/0
ML_MLFLOW_TRACKING_URI=http://localhost:5000
ML_ENVIRONMENT=development
ML_ARTIFACTS_DIR=/tmp/mlflow-artifacts
ML_LOG_LEVEL=INFO

# ─────────────────────────────────────────────────────────────
# Phase 3: Security & Encryption
# ─────────────────────────────────────────────────────────────
# IMPORTANT: Generate a random 32+ char string for production!
# openssl rand -base64 32
ENCRYPTION_KEY=amdox-default-key-CHANGE-IN-PRODUCTION!!
WEBHOOK_SECRET=amdox-webhook-secret-CHANGE-IN-PRODUCTION

# ─────────────────────────────────────────────────────────────
# Phase 3: Email (SMTP)
# ─────────────────────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@amdox.com

# Alternative: Resend (recommended for production)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx

# ─────────────────────────────────────────────────────────────
# Phase 3: Notifications
# ─────────────────────────────────────────────────────────────
NOTIFICATION_POLL_INTERVAL_MS=5000
OUTBOX_POLL_INTERVAL_MS=5000
WEBHOOK_TIMEOUT_MS=10000
WEBHOOK_MAX_RETRIES=3

# ─────────────────────────────────────────────────────────────
# Frontend (apps/web)
# ─────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_ML_URL=http://localhost:8000
NEXT_PUBLIC_TENANT_ID=demo-tenant

# ─────────────────────────────────────────────────────────────
# Docker Compose Overrides
# ─────────────────────────────────────────────────────────────
POSTGRES_PORT=5432
REDIS_PORT=6379
KEYCLOAK_PORT=8080
ELASTICSEARCH_PORT=9200
