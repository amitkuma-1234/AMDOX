# ============================================================
# AMDOX Environment Variables
# ============================================================
# Copy this file to .env and fill in the values.
# DO NOT commit .env files to version control.
# ============================================================

# ---- General ----
NODE_ENV=development
APP_NAME=AMDOX
APP_URL=http://localhost:3000

# ---- Database (PostgreSQL) ----
DATABASE_URL=postgresql://amdox:amdox_secret@localhost:5432/amdox?schema=public
DB_HOST=localhost
DB_PORT=5432
DB_NAME=amdox
DB_USER=amdox
DB_PASSWORD=amdox_secret

# ---- Redis ----
REDIS_URL=redis://localhost:6379
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- Keycloak (Auth) ----
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=amdox
KEYCLOAK_CLIENT_ID=amdox-web
KEYCLOAK_CLIENT_SECRET=your-client-secret
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# ---- Elasticsearch ----
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic_secret

# ---- API ----
API_URL=http://localhost:4000
API_PORT=4000
CORS_ORIGIN=http://localhost:3000

# ---- ML Service ----
ML_SERVICE_URL=http://localhost:8000
ML_SERVICE_PORT=8000

# ---- JWT / Auth ----
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800

# ---- File Storage ----
STORAGE_TYPE=local
STORAGE_PATH=./uploads
# S3_BUCKET=
# S3_REGION=
# S3_ACCESS_KEY=
# S3_SECRET_KEY=

# ---- Email / SMTP ----
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@amdox.dev

# ---- Logging ----
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ---- Feature Flags ----
FEATURE_ML_ENABLED=true
FEATURE_ELASTICSEARCH_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=false

# ---- Docker Compose Overrides ----
POSTGRES_PORT=5432
REDIS_DOCKER_PORT=6379
KEYCLOAK_PORT=8080
ELASTICSEARCH_PORT=9200
