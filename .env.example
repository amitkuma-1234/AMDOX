# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=AMDOX ERP Platform
APP_VERSION=1.0.0
API_PREFIX=api
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Database (PostgreSQL) ────────────────────────────────────
