JWT_REFRESH_TOKEN_EXPIRATION=604800
JWT_ISSUER=http://localhost:8080/realms/amdox
JWT_AUDIENCE=amdox-api
JWKS_URI=http://localhost:8080/realms/amdox/protocol/openid-connect/certs

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ── OpenTelemetry ────────────────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=amdox-api
OTEL_EXPORTER_ENDPOINT=http://localhost:4318

