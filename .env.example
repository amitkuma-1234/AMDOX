# ─────────────────────────────────────────────────────────────
# AMDOX ERP Platform — Environment Configuration
# Copy this file to .env and fill in the actual values
# ─────────────────────────────────────────────────────────────

# ── Application ──────────────────────────────────────────────
NODE_ENV=development
PORT=3000
APP_NAME=AMDOX
APP_VERSION=1.0.0
API_PREFIX=api
CORS_ORIGINS=http://localhost:4200,http://localhost:3000

# ── Database (PostgreSQL) ───────────────────────────────────
# Use localhost for local dev, or the container name for docker
DATABASE_URL=postgresql://amdox:amdox_secret@localhost:5432/amdox?schema=public
POSTGRES_DB=amdox
POSTGRES_USER=amdox
POSTGRES_PASSWORD=amdox_secret
POSTGRES_PORT=5432

# ── Redis ────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=amdox_redis_secret
REDIS_DB=0
REDIS_KEY_PREFIX=amdox:

# ── Keycloak (Auth) ──────────────────────────────────────────
KEYCLOAK_BASE_URL=http://localhost:8080
KEYCLOAK_REALM=amdox
KEYCLOAK_CLIENT_ID=amdox-api
KEYCLOAK_CLIENT_SECRET=change-me-in-production
KEYCLOAK_ADMIN_USER=admin
KEYCLOAK_ADMIN_PASSWORD=admin_secret

# ── JWT / Security ──────────────────────────────────────────
JWT_ACCESS_EXPIRATION=3600
JWT_REFRESH_EXPIRATION=604800
JWT_ISSUER=amdox-api
JWT_AUDIENCE=amdox-api
JWKS_URI=http://localhost:8080/realms/amdox/protocol/openid-connect/certs

# ── Elasticsearch ────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=elastic_secret

# ── Rate Limiting ────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ── OpenTelemetry (Monitoring) ────────────────────────────────
OTEL_ENABLED=false
OTEL_SERVICE_NAME=amdox-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL=debug
LOG_FORMAT=pretty

# ── SMTP (Email) ─────────────────────────────────────────────
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@amdox.dev

# ── Feature Flags ────────────────────────────────────────────
FEATURE_ML_ENABLED=true
FEATURE_ELASTICSEARCH_ENABLED=true
FEATURE_EMAIL_NOTIFICATIONS=false

# ── Docker Compose Overrides ─────────────────────────────────
# These are used by docker-compose.yml
DB_PORT=5432
REDIS_DOCKER_PORT=6379
KEYCLOAK_PORT=8080
ELASTICSEARCH_PORT=9200

