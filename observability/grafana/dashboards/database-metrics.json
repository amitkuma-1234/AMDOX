{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Query Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(db_query_duration_seconds_bucket[5m])) by (le, operation))",
          "legendFormat": "{{ operation }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Active Connections",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "pg_stat_activity_count",
          "legendFormat": "Active"
        },
        {
          "expr": "pg_settings_max_connections",
          "legendFormat": "Max"
        }
      ]
    },
    {
      "title": "Slow Queries (> 500ms)",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "increase(pg_stat_statements_calls_total{querytype=\"slow\"}[1h])",
          "legendFormat": "Count"
        }
      ]
    },
    {
      "title": "Replication Lag",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 8 },
      "targets": [
        {
          "expr": "pg_replication_lag",
          "legendFormat": "Lag"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          }
        }
      }
    },
    {
      "title": "Connection Pool Utilization",
      "type": "gauge",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "pg_stat_activity_count / pg_settings_max_connections * 100",
          "legendFormat": "Utilization"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green", "value": null },
              { "color": "yellow", "value": 70 },
              { "color": "red", "value": 90 }
            ]
          }
        }
      }
    },
    {
      "title": "Database Size",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "pg_database_size_bytes{datname=\"amdox\"}",
          "legendFormat": "Size"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "decbytes" } }
    }
  ],
  "schemaVersion": 39,
  "tags": ["amdox", "database"],
  "time": { "from": "now-1h", "to": "now" },
  "title": "AMDOX Database Metrics",
  "uid": "amdox-db-metrics"
}
