// ─────────────────────────────────────────────────────────────
// AMDOX ERP Platform — Prisma Schema
// Multi-tenant enterprise resource planning database schema
// Database: PostgreSQL 17
// Features: Multi-tenancy, Soft-delete, Audit trail, RLS
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "relationJoins", "multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  PENDING
  DEACTIVATED
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum TransactionStatus {
  PENDING
  POSTED
  REVERSED
  VOIDED
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  POSTED
  REVERSED
  REJECTED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum AccountSubType {
  CURRENT_ASSET
  FIXED_ASSET
  CURRENT_LIABILITY
  LONG_TERM_LIABILITY
  RETAINED_EARNINGS
  OPERATING_REVENUE
  OPERATING_EXPENSE
  OTHER
}

enum Currency {
  USD
  EUR
  GBP
  INR
  AED
  SAR
  JPY
  CNY
  CAD
  AUD
}

enum PurchaseOrderStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum NotificationType {
  INFO
  WARNING
  ERROR
  SUCCESS
  ACTION_REQUIRED
  SYSTEM
}

enum NotificationChannel {
  IN_APP
  EMAIL
  SMS
  PUSH
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  PROBATION
  SUSPENDED
  TERMINATED
  RESIGNED
  RETIRED
}

enum ContractType {
  FULL_TIME
  PART_TIME
  CONTRACT
  INTERN
  FREELANCE
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  SOFT_DELETE
  RESTORE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
}

enum StockStatus {
  IN_STOCK
  LOW_STOCK
  OUT_OF_STOCK
  DISCONTINUED
}

enum FiscalPeriodStatus {
  OPEN
  LOCKED
  CLOSED
}

enum InvoiceStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  VOIDED
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum PayrollStatus {
  DRAFT
  PROCESSING
  COMPLETED
  FAILED
  REVERSED
}

// ─────────────────────────────────────────────────────────────
// MODELS
// ─────────────────────────────────────────────────────────────

model Tenant {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @db.VarChar(255)
  slug             String           @unique @db.VarChar(100)
  domain           String?          @unique @db.VarChar(255)
  subscriptionTier SubscriptionTier @default(FREE)
  status           TenantStatus     @default(PENDING)
  settings         Json?            @default("{}")
  logoUrl          String?          @db.VarChar(500)
  maxUsers         Int              @default(5)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  // Relations
  users          User[]
  roles          Role[]
  accounts       Account[]
  employees      Employee[]
  inventoryItems InventoryItem[]
  purchaseOrders PurchaseOrder[]
  journalEntries JournalEntry[]
  auditLogs      AuditLog[]
  vendors        Vendor[]
  fiscalPeriods  FiscalPeriod[]
  currencyRates  CurrencyRate[]
  apInvoices     ApInvoice[]
  arInvoices     ArInvoice[]
  goodsReceipts  GoodsReceipt[]
  payrolls       Payroll[]

  @@index([slug])
  @@index([status])
  @@index([domain])
  @@index([subscriptionTier])
  @@index([isActive])
  @@index([deletedAt])
  @@map("tenants")
}

model User {
  id              String    @id @default(uuid()) @db.Uuid
  email           String    @db.VarChar(320)
  firstName       String?   @map("first_name") @db.VarChar(100)
  lastName        String?   @map("last_name") @db.VarChar(100)
  keycloakId      String?   @unique @map("keycloak_id") @db.VarChar(255)
  avatarUrl       String?   @map("avatar_url") @db.VarChar(500)
  isActive        Boolean   @default(true) @map("is_active")
  lastLoginAt     DateTime? @map("last_login_at")
  emailVerifiedAt DateTime? @map("email_verified_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")
  deletedAt       DateTime? @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  roles         UserRole[]
  notifications Notification[]
  auditLogs     AuditLog[]
  refreshTokens RefreshToken[]
  employee      Employee?

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([keycloakId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("users")
}

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  displayName String?   @map("display_name") @db.VarChar(255)
  description String?   @db.Text
  permissions Json      @default("[]")
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Tenant relation (null = platform-level role)
  tenantId String? @map("tenant_id") @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  userRoles UserRole[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@index([name])
  @@index([deletedAt])
  @@map("roles")
}

model UserRole {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model RefreshToken {
  id         String    @id @default(uuid()) @db.Uuid
  token      String    @unique @db.VarChar(500)
  userId     String    @map("user_id") @db.Uuid
  expiresAt  DateTime  @map("expires_at")
  isRevoked  Boolean   @default(false) @map("is_revoked")
  revokedAt  DateTime? @map("revoked_at")
  deviceInfo String?   @map("device_info") @db.VarChar(500)
  ipAddress  String?   @map("ip_address") @db.VarChar(45)
  createdAt  DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model Account {
  id             String          @id @default(uuid()) @db.Uuid
  accountName    String          @map("account_name") @db.VarChar(255)
  glCode         String          @map("gl_code") @db.VarChar(50)
  type           AccountType     @map("account_type")
  subType        AccountSubType? @map("account_sub_type")
  currency       Currency        @default(USD)
  description    String?         @db.Text
  parentId       String?         @map("parent_id") @db.Uuid
  isActive       Boolean         @default(true) @map("is_active")
  openingBalance Decimal         @default(0) @map("opening_balance") @db.Decimal(20, 4)
  balance        Decimal         @default(0) @map("current_balance") @db.Decimal(20, 4)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  deletedAt      DateTime?       @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Self-relation for chart of accounts hierarchy
  parent   Account?  @relation("AccountHierarchy", fields: [parentId], references: [id])
  children Account[] @relation("AccountHierarchy")

  // Relations
  transactions Transaction[]

  @@unique([glCode, tenantId])
  @@index([tenantId])
  @@index([type])
  @@index([parentId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("accounts")
}

model Transaction {
  id              String            @id @default(uuid()) @db.Uuid
  amount          Decimal           @db.Decimal(20, 4)
  type            TransactionType
  status          TransactionStatus @default(PENDING)
  currency        Currency          @default(USD)
  description     String?           @db.Text
  reference       String?           @db.VarChar(100)
  exchangeRate    Decimal?          @map("exchange_rate") @db.Decimal(12, 6)
  baseCurrencyAmt Decimal?          @map("base_currency_amount") @db.Decimal(20, 4)
  postingDate     DateTime          @map("posting_date") @db.Date
  createdAt       DateTime          @default(now()) @map("created_at")
  updatedAt       DateTime          @updatedAt @map("updated_at")
  deletedAt       DateTime?         @map("deleted_at")

  // Relations
  accountId      String        @map("account_id") @db.Uuid
  account        Account       @relation(fields: [accountId], references: [id], onDelete: Restrict)
  journalEntryId String?       @map("journal_entry_id") @db.Uuid
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([journalEntryId])
  @@index([type])
  @@index([status])
  @@index([postingDate])
  @@map("transactions")
}

model JournalEntry {
  id          String             @id @default(uuid()) @db.Uuid
  reference   String             @db.VarChar(100)
  description String?            @db.Text
  status      JournalEntryStatus @default(DRAFT)
  entryDate   DateTime           @map("entry_date") @db.Date
  postingDate DateTime?          @map("posting_date") @db.Date
  totalDebit  Decimal            @default(0) @map("total_debit") @db.Decimal(20, 4)
  totalCredit Decimal            @default(0) @map("total_credit") @db.Decimal(20, 4)
  attachments Json?              @default("[]")
  approvedBy  String?            @map("approved_by") @db.Uuid
  approvedAt  DateTime?          @map("approved_at")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  transactions Transaction[]

  @@unique([reference, tenantId])
  @@index([tenantId])
  @@index([status])
  @@index([entryDate])
  @@map("journal_entries")
}

model FiscalPeriod {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @db.VarChar(100) // e.g., "Jan 2024"
  startDate DateTime           @map("start_date") @db.Date
  endDate   DateTime           @map("end_date") @db.Date
  status    FiscalPeriodStatus @default(OPEN)
  tenantId  String             @map("tenant_id") @db.Uuid
  tenant    Tenant             @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([name, tenantId])
  @@index([tenantId])
  @@index([status])
  @@map("fiscal_periods")
}

model CurrencyRate {
  id           String   @id @default(uuid()) @db.Uuid
  fromCurrency Currency @map("from_currency")
  toCurrency   Currency @map("to_currency")
  rate         Decimal  @db.Decimal(18, 6)
  rateDate     DateTime @map("rate_date") @db.Date
  tenantId     String   @map("tenant_id") @db.Uuid
  tenant       Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([fromCurrency, toCurrency, rateDate, tenantId])
  @@index([tenantId])
  @@index([rateDate])
  @@map("currency_rates")
}

model Employee {
  id               String           @id @default(uuid()) @db.Uuid
  employeeCode     String           @map("employee_code") @db.VarChar(50)
  personalInfo     Json             @map("personal_info")
  contactInfo      Json?            @map("contact_info")
  employmentStatus EmploymentStatus @default(PROBATION) @map("employment_status")
  contractType     ContractType     @default(FULL_TIME) @map("contract_type")
  department       String?          @db.VarChar(100)
  position         String?          @db.VarChar(100)
  managerId        String?          @map("manager_id") @db.Uuid
  hireDate         DateTime         @map("hire_date") @db.Date
  terminationDate  DateTime?        @map("termination_date") @db.Date
  salary           Decimal?         @db.Decimal(20, 4)
  salaryCurrency   Currency         @default(USD) @map("salary_currency")
  bankDetails      Json?            @map("bank_details")
  documents        Json?            @default("[]")
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  // Relations
  tenantId String  @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String? @unique @map("user_id") @db.Uuid
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // Self-relation for reporting hierarchy
  manager       Employee?       @relation("EmployeeHierarchy", fields: [managerId], references: [id])
  directReports Employee[]      @relation("EmployeeHierarchy")
  leaveRequests LeaveRequest[]
  payrollItems  PayrollItem[]

  @@unique([employeeCode, tenantId])
  @@index([tenantId])
  @@index([employmentStatus])
  @@index([deletedAt])
  @@map("employees")
}

model LeaveRequest {
  id         String      @id @default(uuid()) @db.Uuid
  leaveType  String      @map("leave_type") @db.VarChar(50)
  startDate  DateTime    @map("start_date") @db.Date
  endDate    DateTime    @map("end_date") @db.Date
  days       Decimal     @db.Decimal(5, 2)
  reason     String?     @db.Text
  status     LeaveStatus @default(PENDING)
  approvedBy String?     @map("approved_by") @db.Uuid
  approvedAt DateTime?   @map("approved_at")
  createdAt  DateTime    @default(now()) @map("created_at")

  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Cascade)

  @@index([employeeId])
  @@index([status])
  @@map("leave_requests")
}

model Payroll {
  id          String        @id @default(uuid()) @db.Uuid
  name        String        @db.VarChar(100) // e.g., "Jan 2024 Monthly"
  periodStart DateTime      @map("period_start") @db.Date
  periodEnd   DateTime      @map("period_end") @db.Date
  status      PayrollStatus @default(DRAFT)
  totalGross  Decimal       @default(0) @map("total_gross") @db.Decimal(20, 4)
  totalNet    Decimal       @default(0) @map("total_net") @db.Decimal(20, 4)
  tenantId    String        @map("tenant_id") @db.Uuid
  tenant      Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  items PayrollItem[]

  @@index([tenantId])
  @@index([status])
  @@map("payrolls")
}

model PayrollItem {
  id           String  @id @default(uuid()) @db.Uuid
  basicSalary  Decimal @map("basic_salary") @db.Decimal(18, 4)
  allowances   Decimal @default(0) @db.Decimal(18, 4)
  deductions   Decimal @default(0) @db.Decimal(18, 4)
  netSalary    Decimal @map("net_salary") @db.Decimal(18, 4)
  taxAmount    Decimal @map("tax_amount") @db.Decimal(18, 4)

  payrollId  String   @map("payroll_id") @db.Uuid
  payroll    Payroll  @relation(fields: [payrollId], references: [id], onDelete: Cascade)
  employeeId String   @map("employee_id") @db.Uuid
  employee   Employee @relation(fields: [employeeId], references: [id], onDelete: Restrict)

  @@index([payrollId])
  @@index([employeeId])
  @@map("payroll_items")
}

model Vendor {
  id            String    @id @default(uuid()) @db.Uuid
  code          String    @db.VarChar(50)
  name          String    @db.VarChar(255)
  contactPerson String?   @map("contact_person") @db.VarChar(255)
  email         String?   @db.VarChar(320)
  phone         String?   @db.VarChar(50)
  address       Json?
  taxId         String?   @map("tax_id") @db.VarChar(100)
  paymentTerms  String?   @map("payment_terms") @db.VarChar(100)
  currency      Currency  @default(USD)
  rating        Int?      @default(0)
  isActive      Boolean   @default(true) @map("is_active")
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  // Relations
  purchaseOrders PurchaseOrder[]
  apInvoices     ApInvoice[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([isActive])
  @@index([deletedAt])
  @@map("vendors")
}

model ApInvoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @map("invoice_number") @db.VarChar(100)
  invoiceDate   DateTime      @map("invoice_date") @db.Date
  dueDate       DateTime      @map("due_date") @db.Date
  status        InvoiceStatus @default(DRAFT)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(20, 4)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(20, 4)
  currency      Currency      @default(USD)
  attachments   Json?         @default("[]")
  createdAt     DateTime      @default(now()) @map("created_at")

  vendorId String @map("vendor_id") @db.Uuid
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([invoiceNumber, vendorId, tenantId])
  @@index([tenantId])
  @@index([vendorId])
  @@index([status])
  @@map("ap_invoices")
}

model ArInvoice {
  id            String        @id @default(uuid()) @db.Uuid
  invoiceNumber String        @map("invoice_number") @db.VarChar(100)
  invoiceDate   DateTime      @map("invoice_date") @db.Date
  dueDate       DateTime      @map("due_date") @db.Date
  status        InvoiceStatus @default(DRAFT)
  totalAmount   Decimal       @map("total_amount") @db.Decimal(20, 4)
  taxAmount     Decimal       @default(0) @map("tax_amount") @db.Decimal(20, 4)
  currency      Currency      @default(USD)
  customerName  String        @map("customer_name") @db.VarChar(255)
  customerEmail String?       @map("customer_email") @db.VarChar(320)
  createdAt     DateTime      @default(now()) @map("created_at")

  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([invoiceNumber, tenantId])
  @@index([tenantId])
  @@index([status])
  @@map("ar_invoices")
}

model PurchaseOrder {
  id              String              @id @default(uuid()) @db.Uuid
  orderNumber     String              @map("order_number") @db.VarChar(50)
  status          PurchaseOrderStatus @default(DRAFT)
  items           Json                @default("[]")
  subtotal        Decimal             @default(0) @db.Decimal(20, 4)
  taxAmount       Decimal             @default(0) @map("tax_amount") @db.Decimal(20, 4)
  shippingCost    Decimal             @default(0) @map("shipping_cost") @db.Decimal(20, 4)
  totalAmount     Decimal             @default(0) @map("total_amount") @db.Decimal(20, 4)
  currency        Currency            @default(USD)
  notes           String?             @db.Text
  expectedDate    DateTime?           @map("expected_date") @db.Date
  receivedDate    DateTime?           @map("received_date") @db.Date
  approvedBy      String?             @map("approved_by") @db.Uuid
  approvedAt      DateTime?           @map("approved_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  // Relations
  vendorId      String         @map("vendor_id") @db.Uuid
  vendor        Vendor         @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  tenantId      String         @map("tenant_id") @db.Uuid
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  goodsReceipts GoodsReceipt[]

  @@unique([orderNumber, tenantId])
  @@index([tenantId])
  @@index([vendorId])
  @@index([status])
  @@index([deletedAt])
  @@map("purchase_orders")
}

model GoodsReceipt {
  id            String    @id @default(uuid()) @db.Uuid
  receiptNumber String    @map("receipt_number") @db.VarChar(50)
  receivedDate  DateTime  @map("received_date") @db.Date
  items         Json      @default("[]")
  notes         String?   @db.Text
  createdAt     DateTime  @default(now()) @map("created_at")

  purchaseOrderId String        @map("purchase_order_id") @db.Uuid
  purchaseOrder   PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Restrict)
  tenantId        String        @map("tenant_id") @db.Uuid
  tenant          Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([receiptNumber, tenantId])
  @@index([tenantId])
  @@index([purchaseOrderId])
  @@map("goods_receipts")
}

model InventoryItem {
  id              String      @id @default(uuid()) @db.Uuid
  sku             String      @db.VarChar(100)
  name            String      @db.VarChar(255)
  description     String?     @db.Text
  category        String?     @db.VarChar(100)
  unit            String      @default("pcs") @db.VarChar(20)
  currentStock    Int         @default(0) @map("current_stock")
  reservedStock   Int         @default(0) @map("reserved_stock")
  reorderLevel    Int         @default(10) @map("reorder_level")
  reorderQuantity Int         @default(50) @map("reorder_quantity")
  unitCost        Decimal     @default(0) @map("unit_cost") @db.Decimal(14, 4)
  sellingPrice    Decimal?    @map("selling_price") @db.Decimal(14, 4)
  currency        Currency    @default(USD)
  stockStatus     StockStatus @default(IN_STOCK) @map("stock_status")
  location        String?     @db.VarChar(100)
  barcode         String?     @db.VarChar(100)
  attributes      Json?       @default("{}")
  isActive        Boolean     @default(true) @map("is_active")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")
  deletedAt       DateTime?   @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  movements StockMovement[]

  @@unique([sku, tenantId])
  @@index([tenantId])
  @@index([stockStatus])
  @@index([deletedAt])
  @@map("inventory_items")
}

model StockMovement {
  id        String   @id @default(uuid()) @db.Uuid
  quantity  Int
  type      String   @db.VarChar(20) // IN, OUT, ADJUST, TRANSFER
  reason    String?  @db.Text
  reference String?  @db.VarChar(100)
  timestamp DateTime @default(now())

  inventoryItemId String        @map("inventory_item_id") @db.Uuid
  inventoryItem   InventoryItem @relation(fields: [inventoryItemId], references: [id], onDelete: Cascade)

  @@index([inventoryItemId])
  @@index([timestamp])
  @@map("stock_movements")
}

model Notification {
  id        String              @id @default(uuid()) @db.Uuid
  title     String              @db.VarChar(255)
  body      String              @db.Text
  type      NotificationType    @default(INFO)
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus  @default(PENDING)
  metadata  Json?               @default("{}")
  readAt    DateTime?           @map("read_at")
  sentAt    DateTime?           @map("sent_at")
  expiresAt DateTime?           @map("expires_at")
  createdAt DateTime            @default(now()) @map("created_at")
  updatedAt DateTime            @updatedAt @map("updated_at")
  deletedAt DateTime?           @map("deleted_at")

  // Relations
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([deletedAt])
  @@map("notifications")
}

model AuditLog {
  id            String      @id @default(uuid()) @db.Uuid
  entityType    String      @map("entity_type") @db.VarChar(100)
  entityId      String      @map("entity_id") @db.VarChar(255)
  action        AuditAction
  oldValue      Json?       @map("old_value")
  newValue      Json?       @map("new_value")
  changedFields String[]    @map("changed_fields")
  ipAddress     String?     @map("ip_address") @db.VarChar(45)
  userAgent     String?     @map("user_agent") @db.VarChar(500)
  metadata      Json?       @default("{}")
  timestamp     DateTime    @default(now())

  // Relations
  userId   String? @map("user_id") @db.Uuid
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  tenantId String  @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([timestamp])
  @@map("audit_logs")
}
