// ─────────────────────────────────────────────────────────────
// AMDOX ERP Platform — Prisma Schema
// Multi-tenant enterprise resource planning database schema
// ─────────────────────────────────────────────────────────────

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "multiSchema"]
  binaryTargets   = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum SubscriptionTier {
  FREE
  STARTER
  PROFESSIONAL
  ENTERPRISE
}

enum TransactionType {
  DEBIT
  CREDIT
}

enum JournalEntryStatus {
  DRAFT
  PENDING_APPROVAL
  POSTED
  REVERSED
  VOIDED
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  REVENUE
  EXPENSE
}

enum PurchaseOrderStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PARTIALLY_RECEIVED
  RECEIVED
  CANCELLED
  CLOSED
}

enum NotificationType {
  SYSTEM
  ALERT
  REMINDER
  APPROVAL_REQUEST
  AUDIT
  REPORT
}

enum NotificationChannel {
  EMAIL
  SMS
  PUSH
  IN_APP
}

enum NotificationStatus {
  PENDING
  SENT
  DELIVERED
  READ
  FAILED
}

enum EmploymentStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  TERMINATED
  RETIRED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  RESTORE
  LOGIN
  LOGOUT
  EXPORT
  IMPORT
  APPROVE
  REJECT
}

// ─────────────────────────────────────────────────────────────
// TENANT — Root entity for multi-tenancy
// RLS Policy: All tenant-scoped queries MUST include tenantId
// ─────────────────────────────────────────────────────────────

model Tenant {
  id               String           @id @default(uuid()) @db.Uuid
  name             String           @db.VarChar(255)
  slug             String           @unique @db.VarChar(100)
  domain           String?          @unique @db.VarChar(255)
  subscriptionTier SubscriptionTier @default(FREE)
  settings         Json             @default("{}")
  logoUrl          String?          @db.VarChar(500)
  isActive         Boolean          @default(true)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  // Relations
  users          User[]
  roles          Role[]
  accounts       Account[]
  journalEntries JournalEntry[]
  employees      Employee[]
  purchaseOrders PurchaseOrder[]
  inventoryItems InventoryItem[]

  @@index([slug])
  @@index([domain])
  @@index([subscriptionTier])
  @@index([isActive])
  @@index([deletedAt])
  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────
// USER — Authenticated users linked to Keycloak
// RLS: Filter by tenantId for all non-super_admin queries
// ─────────────────────────────────────────────────────────────

model User {
  id          String    @id @default(uuid()) @db.Uuid
  email       String    @db.VarChar(320)
  keycloakId  String    @unique @map("keycloak_id") @db.VarChar(255)
  firstName   String?   @map("first_name") @db.VarChar(100)
  lastName    String?   @map("last_name") @db.VarChar(100)
  avatarUrl   String?   @map("avatar_url") @db.VarChar(500)
  isActive    Boolean   @default(true)
  lastLoginAt DateTime? @map("last_login_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  tenantId      String         @map("tenant_id") @db.Uuid
  tenant        Tenant         @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  roles         UserRole[]
  notifications Notification[]
  auditLogs     AuditLog[]     @relation("PerformedByUser")
  employee      Employee?

  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([keycloakId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([tenantId, email])
  @@index([tenantId, isActive])
  @@map("users")
}

// ─────────────────────────────────────────────────────────────
// ROLE — Roles with JSON permission arrays, scoped per tenant
// RLS: Filter by tenantId
// ─────────────────────────────────────────────────────────────

model Role {
  id          String    @id @default(uuid()) @db.Uuid
  name        String    @db.VarChar(100)
  description String?   @db.VarChar(500)
  permissions Json      @default("[]")
  isSystem    Boolean   @default(false) @map("is_system")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")
  deletedAt   DateTime? @map("deleted_at")

  // Relations
  tenantId String   @map("tenant_id") @db.Uuid
  tenant   Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users    UserRole[]

  @@unique([name, tenantId])
  @@index([tenantId])
  @@index([name])
  @@index([deletedAt])
  @@index([tenantId, name])
  @@map("roles")
}

// ─────────────────────────────────────────────────────────────
// USER_ROLE — Many-to-many join table for User <-> Role
// ─────────────────────────────────────────────────────────────

model UserRole {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

// ─────────────────────────────────────────────────────────────
// ACCOUNT — Chart of Accounts with GL codes (multi-currency)
// RLS: Filter by tenantId
// ─────────────────────────────────────────────────────────────

model Account {
  id          String      @id @default(uuid()) @db.Uuid
  accountName String      @map("account_name") @db.VarChar(255)
  glCode      String      @map("gl_code") @db.VarChar(20)
  type        AccountType
  currency    String      @default("USD") @db.VarChar(3)
  description String?     @db.VarChar(500)
  parentId    String?     @map("parent_id") @db.Uuid
  isActive    Boolean     @default(true)
  balance     Decimal     @default(0) @db.Decimal(20, 4)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @updatedAt @map("updated_at")
  deletedAt   DateTime?   @map("deleted_at")

  // Relations
  tenantId     String        @map("tenant_id") @db.Uuid
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  parent       Account?      @relation("AccountHierarchy", fields: [parentId], references: [id])
  children     Account[]     @relation("AccountHierarchy")
  transactions Transaction[]

  @@unique([glCode, tenantId])
  @@index([tenantId])
  @@index([glCode])
  @@index([type])
  @@index([currency])
  @@index([parentId])
  @@index([isActive])
  @@index([deletedAt])
  @@index([tenantId, glCode])
  @@index([tenantId, type])
  @@index([tenantId, isActive])
  @@map("accounts")
}

// ─────────────────────────────────────────────────────────────
// TRANSACTION — Financial transactions (debits and credits)
// RLS: Filter via Account -> tenantId
// ─────────────────────────────────────────────────────────────

model Transaction {
  id          String          @id @default(uuid()) @db.Uuid
  amount      Decimal         @db.Decimal(20, 4)
  type        TransactionType
  currency    String          @default("USD") @db.VarChar(3)
  description String?         @db.VarChar(500)
  reference   String?         @db.VarChar(100)
  metadata    Json?           @default("{}")
  postedAt    DateTime?       @map("posted_at")
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")
  deletedAt   DateTime?       @map("deleted_at")

  // Relations
  accountId      String       @map("account_id") @db.Uuid
  account        Account      @relation(fields: [accountId], references: [id], onDelete: Restrict)
  journalEntryId String?      @map("journal_entry_id") @db.Uuid
  journalEntry   JournalEntry? @relation(fields: [journalEntryId], references: [id], onDelete: SetNull)

  @@index([accountId])
  @@index([journalEntryId])
  @@index([type])
  @@index([postedAt])
  @@index([createdAt])
  @@index([deletedAt])
  @@index([accountId, type])
  @@index([accountId, createdAt])
  @@index([journalEntryId, type])
  @@map("transactions")
}

// ─────────────────────────────────────────────────────────────
// JOURNAL ENTRY — Groups transactions for double-entry bookkeeping
// RLS: Filter by tenantId
// ─────────────────────────────────────────────────────────────

model JournalEntry {
  id          String             @id @default(uuid()) @db.Uuid
  reference   String             @db.VarChar(50)
  description String?            @db.VarChar(500)
  status      JournalEntryStatus @default(DRAFT)
  totalAmount Decimal            @default(0) @map("total_amount") @db.Decimal(20, 4)
  currency    String             @default("USD") @db.VarChar(3)
  postedAt    DateTime?          @map("posted_at")
  postedBy    String?            @map("posted_by") @db.Uuid
  reversedAt  DateTime?          @map("reversed_at")
  reversedBy  String?            @map("reversed_by") @db.Uuid
  metadata    Json?              @default("{}")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  deletedAt   DateTime?          @map("deleted_at")

  // Relations
  tenantId     String        @map("tenant_id") @db.Uuid
  tenant       Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  transactions Transaction[]

  @@unique([reference, tenantId])
  @@index([tenantId])
  @@index([reference])
  @@index([status])
  @@index([postedAt])
  @@index([deletedAt])
  @@index([tenantId, status])
  @@index([tenantId, reference])
  @@map("journal_entries")
}

// ─────────────────────────────────────────────────────────────
// EMPLOYEE — HR entity with personal info and contract (JSON)
// RLS: Filter by tenantId
// ─────────────────────────────────────────────────────────────

model Employee {
  id               String           @id @default(uuid()) @db.Uuid
  employeeNumber   String           @map("employee_number") @db.VarChar(50)
  personalInfo     Json             @map("personal_info") @default("{}")
  contract         Json             @default("{}")
  position         String?          @db.VarChar(200)
  department       String?          @db.VarChar(200)
  employmentStatus EmploymentStatus @default(ACTIVE) @map("employment_status")
  hireDate         DateTime         @map("hire_date")
  terminationDate  DateTime?        @map("termination_date")
  salary           Decimal?         @db.Decimal(20, 4)
  currency         String           @default("USD") @db.VarChar(3)
  createdAt        DateTime         @default(now()) @map("created_at")
  updatedAt        DateTime         @updatedAt @map("updated_at")
  deletedAt        DateTime?        @map("deleted_at")

  // Relations
  tenantId String  @map("tenant_id") @db.Uuid
  tenant   Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId   String? @unique @map("user_id") @db.Uuid
  user     User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@unique([employeeNumber, tenantId])
  @@index([tenantId])
  @@index([employeeNumber])
  @@index([employmentStatus])
  @@index([department])
  @@index([deletedAt])
  @@index([tenantId, employmentStatus])
  @@index([tenantId, department])
  @@map("employees")
}

// ─────────────────────────────────────────────────────────────
// PURCHASE ORDER — Procurement with vendor and line items (JSON)
// RLS: Filter by tenantId
// ─────────────────────────────────────────────────────────────

model PurchaseOrder {
  id            String              @id @default(uuid()) @db.Uuid
  poNumber      String              @map("po_number") @db.VarChar(50)
  vendorId      String              @map("vendor_id") @db.VarChar(255)
  vendorName    String              @map("vendor_name") @db.VarChar(255)
  status        PurchaseOrderStatus @default(DRAFT)
  items         Json                @default("[]")
  subtotal      Decimal             @default(0) @db.Decimal(20, 4)
  taxAmount     Decimal             @default(0) @map("tax_amount") @db.Decimal(20, 4)
  totalAmount   Decimal             @default(0) @map("total_amount") @db.Decimal(20, 4)
  currency      String              @default("USD") @db.VarChar(3)
  notes         String?             @db.Text
  approvedBy    String?             @map("approved_by") @db.Uuid
  approvedAt    DateTime?           @map("approved_at")
  expectedDate  DateTime?           @map("expected_date")
  receivedDate  DateTime?           @map("received_date")
  createdAt     DateTime            @default(now()) @map("created_at")
  updatedAt     DateTime            @updatedAt @map("updated_at")
  deletedAt     DateTime?           @map("deleted_at")

  // Relations
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([poNumber, tenantId])
  @@index([tenantId])
  @@index([vendorId])
  @@index([status])
  @@index([deletedAt])
  @@index([tenantId, status])
  @@index([tenantId, vendorId])
  @@index([createdAt])
  @@map("purchase_orders")
}

// ─────────────────────────────────────────────────────────────
// INVENTORY ITEM — Stock tracking with reorder levels
// RLS: Filter by tenantId
// ─────────────────────────────────────────────────────────────

model InventoryItem {
  id            String    @id @default(uuid()) @db.Uuid
  sku           String    @db.VarChar(100)
  name          String    @db.VarChar(255)
  description   String?   @db.VarChar(500)
  category      String?   @db.VarChar(100)
  currentStock  Int       @default(0) @map("current_stock")
  reservedStock Int       @default(0) @map("reserved_stock")
  reorderLevel  Int       @default(0) @map("reorder_level")
  reorderQty    Int       @default(0) @map("reorder_qty")
  unitPrice     Decimal   @default(0) @map("unit_price") @db.Decimal(20, 4)
  currency      String    @default("USD") @db.VarChar(3)
  location      String?   @db.VarChar(100)
  metadata      Json?     @default("{}")
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Relations
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([sku, tenantId])
  @@index([tenantId])
  @@index([sku])
  @@index([category])
  @@index([currentStock])
  @@index([isActive])
  @@index([deletedAt])
  @@index([tenantId, sku])
  @@index([tenantId, category])
  @@index([tenantId, isActive])
  @@map("inventory_items")
}

// ─────────────────────────────────────────────────────────────
// NOTIFICATION — User notifications across channels
// RLS: Filter via User -> tenantId
// ─────────────────────────────────────────────────────────────

model Notification {
  id        String             @id @default(uuid()) @db.Uuid
  title     String             @db.VarChar(255)
  body      String             @db.Text
  type      NotificationType   @default(SYSTEM)
  channel   NotificationChannel @default(IN_APP)
  status    NotificationStatus @default(PENDING)
  metadata  Json?              @default("{}")
  readAt    DateTime?          @map("read_at")
  sentAt    DateTime?          @map("sent_at")
  createdAt DateTime           @default(now()) @map("created_at")
  updatedAt DateTime           @updatedAt @map("updated_at")
  deletedAt DateTime?          @map("deleted_at")

  // Relations
  userId String @map("user_id") @db.Uuid
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([type])
  @@index([channel])
  @@index([status])
  @@index([readAt])
  @@index([deletedAt])
  @@index([userId, status])
  @@index([userId, type])
  @@index([createdAt])
  @@map("notifications")
}

// ─────────────────────────────────────────────────────────────
// AUDIT LOG — Immutable audit trail for all entity changes
// Note: No soft-delete — audit logs are permanent
// RLS: System-wide, filtered by tenantId in queries
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id          String      @id @default(uuid()) @db.Uuid
  entityType  String      @map("entity_type") @db.VarChar(100)
  entityId    String      @map("entity_id") @db.VarChar(255)
  action      AuditAction
  oldValue    Json?       @map("old_value")
  newValue    Json?       @map("new_value")
  metadata    Json?       @default("{}")
  ipAddress   String?     @map("ip_address") @db.VarChar(45)
  userAgent   String?     @map("user_agent") @db.VarChar(500)
  tenantId    String      @map("tenant_id") @db.Uuid
  timestamp   DateTime    @default(now())

  // Relations
  performedBy String? @map("performed_by") @db.Uuid
  user        User?   @relation("PerformedByUser", fields: [performedBy], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([tenantId])
  @@index([performedBy])
  @@index([action])
  @@index([timestamp])
  @@index([tenantId, entityType])
  @@index([tenantId, timestamp])
  @@index([entityType, entityId, timestamp])
  @@map("audit_logs")
}
