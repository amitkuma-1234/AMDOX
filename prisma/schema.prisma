model Vendor {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  code          String   @db.VarChar(50)
  contactPerson String?  @map("contact_person") @db.VarChar(255)
  email         String?  @db.VarChar(320)
  phone         String?  @db.VarChar(50)
  address       Json?
  taxId         String?  @map("tax_id") @db.VarChar(100)
  paymentTerms  String?  @map("payment_terms") @db.VarChar(100)
  currency      Currency @default(USD)
  rating        Int?     @default(0)
  isActive      Boolean  @default(true) @map("is_active")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")
  deletedAt     DateTime? @map("deleted_at")

  // Tenant relation
  tenantId String @map("tenant_id") @db.Uuid

  // Relations
  purchaseOrders PurchaseOrder[]

  @@unique([code, tenantId])
  @@index([tenantId])
  @@index([code])
  @@index([name])
  @@index([isActive])
  @@index([deletedAt])
  @@map("vendors")
}

model PurchaseOrder {
  id              String              @id @default(uuid()) @db.Uuid
  orderNumber     String              @map("order_number") @db.VarChar(50)
  status          PurchaseOrderStatus @default(DRAFT)
  items           Json                @default("[]")
  // items schema: [{ description, quantity, unitPrice, totalPrice, inventoryItemId? }]
  subtotal        Decimal             @default(0) @db.Decimal(20, 4)
  taxAmount       Decimal             @default(0) @map("tax_amount") @db.Decimal(20, 4)
  shippingCost    Decimal             @default(0) @map("shipping_cost") @db.Decimal(20, 4)
  totalAmount     Decimal             @default(0) @map("total_amount") @db.Decimal(20, 4)
  currency        Currency            @default(USD)
  notes           String?             @db.Text
  expectedDate    DateTime?           @map("expected_date") @db.Date
  receivedDate    DateTime?           @map("received_date") @db.Date
  approvedBy      String?             @map("approved_by") @db.Uuid
  approvedAt      DateTime?           @map("approved_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  deletedAt       DateTime?           @map("deleted_at")

  // Relations
  vendorId String @map("vendor_id") @db.Uuid
  vendor   Vendor @relation(fields: [vendorId], references: [id], onDelete: Restrict)
  tenantId String @map("tenant_id") @db.Uuid
  tenant   Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([orderNumber, tenantId])
  @@index([tenantId])
  @@index([vendorId])
  @@index([orderNumber])
  @@index([status])
  @@index([expectedDate])
  @@index([deletedAt])
  @@map("purchase_orders")
}

