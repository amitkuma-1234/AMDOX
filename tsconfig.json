{
  "compilerOptions": {
    "rootDir": "./",
    "baseUrl": "./",
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "node",
    "lib": [
      "dom",
      "dom.iterable",
      "esnext"
    ],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    // Fix for TS17004 (JSX errors)
    "jsx": "preserve",
    // Fix for TS4111 (Property access errors)
    "noPropertyAccessFromIndexSignature": false,
    // Silence deprecation warning from previous step
    "ignoreDeprecations": "5.0",
    "paths": {
      "@/*": [
        "./src/*"
      ]
    }
  },
  "include": [
    "src/**/*.ts",
    "apps/**/*.ts",
    "apps/**/*.tsx", // Includes Next.js pages
    "test/**/*.ts",
    "test/**/*.e2e-spec.ts",
    "commitlint.config.js",
    "next-env.d.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}